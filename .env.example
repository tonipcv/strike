# Strike Security Scanner - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# LLM Provider API Keys
# ============================================================================

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude 3)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here

# OpenRouter (Access to multiple models)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# Ollama (Local LLM - no API key needed)
OLLAMA_HOST=http://ollama:11434

# ============================================================================
# Strike Configuration
# ============================================================================

# Log level: trace, debug, info, warn, error
STRIKE_LOG_LEVEL=info

# Maximum concurrent scans
STRIKE_MAX_CONCURRENT_SCANS=5

# Default timeout for scans (seconds)
STRIKE_TIMEOUT=3600

# Safe mode (require confirmation for destructive actions)
STRIKE_SAFE_MODE=true

# ============================================================================
# Database Configuration (Optional)
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://striker:strike-db-pass@postgres:5432/strike

# PostgreSQL credentials
POSTGRES_DB=strike
POSTGRES_USER=striker
POSTGRES_PASSWORD=strike-db-pass

# ============================================================================
# Redis Configuration (Optional)
# ============================================================================

# Redis connection string
REDIS_URL=redis://redis:6379

# Redis password
REDIS_PASSWORD=strike-redis-pass

# ============================================================================
# Tool Paths (Auto-configured in Docker)
# ============================================================================

NMAP_PATH=/usr/bin/nmap
MASSCAN_PATH=/usr/bin/masscan
NUCLEI_PATH=/usr/local/bin/nuclei
NIKTO_PATH=/usr/local/bin/nikto
SQLMAP_PATH=/home/striker/venv/bin/sqlmap
GOBUSTER_PATH=/usr/local/bin/gobuster
FFUF_PATH=/usr/local/bin/ffuf
SUBFINDER_PATH=/usr/local/bin/subfinder
HTTPX_PATH=/usr/local/bin/httpx
AMASS_PATH=/usr/local/bin/amass
WPSCAN_PATH=/usr/local/bin/wpscan
TESTSSL_PATH=/usr/local/bin/testssl

# ============================================================================
# Advanced Configuration
# ============================================================================

# Enable experimental features
STRIKE_EXPERIMENTAL=false

# Custom workflow directory
STRIKE_WORKFLOW_DIR=/home/striker/workflows

# Report output directory
STRIKE_REPORT_DIR=/home/striker/reports

# Nuclei templates directory
NUCLEI_TEMPLATES_DIR=/home/striker/nuclei-templates

# ============================================================================
# Proxy Configuration (Optional)
# ============================================================================

# HTTP/HTTPS proxy
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ============================================================================
# Notification Configuration (Optional)
# ============================================================================

# Slack webhook for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Email notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=strike@example.com
# SMTP_TO=security-team@example.com
